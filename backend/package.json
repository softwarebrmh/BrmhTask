{
  "name": "bhrm-teams-backend",
  "version": "1.0.0",
  "description": "BHRM Teams Enterprise Task-Centric Execution Platform API",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "dev": "kill -9 $(lsof -ti:3000) 2>/dev/null; nest start --watch",
    "start:dev": "kill -9 $(lsof -ti:3000) 2>/dev/null; nest start --watch",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node -r tsconfig-paths/register prisma/seed.ts",
    "prisma:reset": "prisma migrate reset --force",
    "db:setup": "prisma migrate dev --name init && npm run prisma:seed"
  },
  "prisma": {
    "seed": "ts-node -r tsconfig-paths/register prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/swagger": "^7.0.0",
    "@nestjs/mapped-types": "^2.0.0",
    "@prisma/client": "^5.0.0",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.0",
    "bcrypt": "^5.1.0",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.0",
    "multer": "^1.4.5-lts.1",
    "file-type": "^16.5.4",
    "nodemailer": "^6.9.0",
    "crypto": "^1.0.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^4.17.17",
    "@types/multer": "^1.4.7",
    "@types/bcrypt": "^5.0.0",
    "@types/nodemailer": "^6.4.0",
    "@types/passport-jwt": "^3.0.8",
    "@types/node": "^20.0.0",
    "prisma": "^5.0.0",
    "typescript": "^5.0.0",
    "ts-node": "^10.9.0"
  }
}
