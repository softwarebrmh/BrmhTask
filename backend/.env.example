# ─────────────────────────────────────────
# Application
# ─────────────────────────────────────────
NODE_ENV=development
PORT=3000
# Comma-separate multiple origins in production, e.g. FRONTEND_URL=https://app.vercel.app,https://staging.vercel.app
FRONTEND_URL=http://localhost:3001

# ─────────────────────────────────────────
# Database (local PostgreSQL)
# In production (Railway), this is injected automatically when you
# attach a Postgres plugin — reference it as ${{Postgres.DATABASE_URL}}
# ─────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/bhrm_teams"

# ─────────────────────────────────────────
# JWT
# ─────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret-minimum-32-chars
JWT_EXPIRES_IN=7d

# ─────────────────────────────────────────
# File uploads (local)
# ─────────────────────────────────────────
UPLOAD_DIR=uploads

# ─────────────────────────────────────────
# Email (SMTP)
# ─────────────────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
SMTP_FROM="BHRM Teams <noreply@bhrm.local>"
